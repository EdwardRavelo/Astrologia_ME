---
import { monthlyAnalysis } from '../data/analysis';
---

<section id="analisis" class="py-24 px-4">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-14">
      <div class="section-subtitle">Mes a mes</div>
      <h2 class="section-title">Análisis Mensual</h2>
      <p class="text-silver-300 max-w-xl mx-auto">Cada mes tiene su propio clima astrológico y su oportunidad particular</p>
    </div>

    <div class="space-y-3" id="accordionContainer">
      {monthlyAnalysis.map((month, idx) => (
        <div
          class={`rounded-xl border overflow-hidden transition-all duration-300 ${
            month.isSpecial
              ? 'border-gold-400/50'
              : 'border-space-700'
          }`}
        >
          <!-- Header -->
          <button
            class={`accordion-trigger w-full flex items-center justify-between px-6 py-5 text-left transition-all duration-200 hover:bg-space-700/30 ${
              month.isSpecial ? 'bg-gold-400/5' : 'bg-space-800'
            }`}
            data-index={idx}
            aria-expanded="false"
          >
            <div class="flex items-center gap-4">
              {month.isSpecial && (
                <span class="text-gold-400 text-lg">✦</span>
              )}
              <div>
                <div class={`font-serif text-xl ${month.isSpecial ? 'text-gold-300' : 'text-star-white'}`}>
                  {month.month}
                </div>
                <div class="text-silver-300 text-sm">{month.subtitle}</div>
              </div>
            </div>
            <div class="flex items-center gap-3">
              {month.specialNote && (
                <span class="hidden sm:block badge-gold text-[10px]">{month.specialNote}</span>
              )}
              <span class="accordion-icon text-gold-400 text-xl font-mono transition-transform duration-300">+</span>
            </div>
          </button>

          <!-- Content -->
          <div class="accordion-content max-h-0 opacity-0" data-content={idx}>
            <div class={`px-6 pb-6 pt-2 ${month.isSpecial ? 'bg-gold-400/3' : 'bg-space-800'}`}>
              {month.specialNote && (
                <div class="mb-4 sm:hidden">
                  <span class="badge-gold text-xs">{month.specialNote}</span>
                </div>
              )}

              <!-- Events list -->
              {month.events && month.events.length > 0 && (
                <div class="flex flex-wrap gap-2 mb-5">
                  {month.events.map((ev) => (
                    <span class={`text-xs font-mono px-3 py-1 rounded-full border ${
                      ev.includes('★')
                        ? 'bg-gold-400/10 text-gold-300 border-gold-400/30'
                        : 'bg-space-700/50 text-silver-300 border-space-700'
                    }`}>
                      {ev}
                    </span>
                  ))}
                </div>
              )}

              <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
                <!-- Edward -->
                <div>
                  <div class="flex items-center gap-2 mb-2">
                    <span class="text-gold-400 font-mono">☉</span>
                    <span class="text-gold-300 text-xs font-mono uppercase tracking-widest">Edward</span>
                  </div>
                  <p class="text-silver-300 text-sm leading-relaxed">{month.edward}</p>
                </div>

                <!-- Martina -->
                <div>
                  <div class="flex items-center gap-2 mb-2">
                    <span class="text-nebula-purple font-mono">☽</span>
                    <span class="text-purple-300 text-xs font-mono uppercase tracking-widest">Martina</span>
                  </div>
                  <p class="text-silver-300 text-sm leading-relaxed">{month.martina}</p>
                </div>

                <!-- Together -->
                <div>
                  <div class="flex items-center gap-2 mb-2">
                    <span class="text-star-white font-mono">♥</span>
                    <span class="text-star-white text-xs font-mono uppercase tracking-widest">En pareja</span>
                  </div>
                  <p class="text-silver-300 text-sm leading-relaxed">{month.couple}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const triggers = document.querySelectorAll<HTMLButtonElement>('.accordion-trigger');

  triggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const idx = trigger.dataset.index;
      const content = document.querySelector<HTMLElement>(`[data-content="${idx}"]`);
      const icon = trigger.querySelector<HTMLElement>('.accordion-icon');
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      if (isOpen) {
        trigger.setAttribute('aria-expanded', 'false');
        if (content) {
          content.style.maxHeight = '0px';
          content.style.opacity = '0';
        }
        if (icon) {
          icon.style.transform = 'rotate(0deg)';
          icon.textContent = '+';
        }
      } else {
        trigger.setAttribute('aria-expanded', 'true');
        if (content) {
          content.style.maxHeight = content.scrollHeight + 'px';
          content.style.opacity = '1';
        }
        if (icon) {
          icon.style.transform = 'rotate(45deg)';
          icon.textContent = '+';
        }
      }
    });
  });

  // Auto-open current month based on today
  const today = new Date();
  const currentMonthIdx = today.getMonth(); // 0=Jan
  // Map our months: May=4, Jun=5, Jul=6, Aug=7, Sep=8, Oct-Nov=9, Nov-Dec=10
  const monthMapping: Record<number, number> = { 3: 0, 4: 1, 5: 2, 6: 3, 7: 4, 8: 5, 9: 6, 10: 7, 11: 7 };
  const openIdx = monthMapping[currentMonthIdx];
  if (openIdx !== undefined) {
    const trigger = triggers[openIdx];
    if (trigger) trigger.click();
  }
</script>
