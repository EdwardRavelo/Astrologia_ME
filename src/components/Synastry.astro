---
import { synastryConnections, synastryTensions } from '../data/synastry';
---

<section id="sinastria" class="py-24 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-14">
      <div class="section-subtitle">Cartas combinadas</div>
      <h2 class="section-title">Sinastría</h2>
      <p class="text-silver-300 max-w-xl mx-auto">La intersección entre dos cartas: lo que nace cuando se encuentran</p>
    </div>

    <!-- Central tension note -->
    <div class="card synastry-central mb-12 text-center border-nebula-purple/40 glow-purple max-w-2xl mx-auto"
         style="background: linear-gradient(135deg, rgba(107,91,149,0.1), rgba(13,13,43,0.8))">
      <div class="text-nebula-purple text-xs font-mono uppercase tracking-widest mb-3">Tensión central</div>
      <h3 class="font-serif text-2xl text-star-white mb-3">☉ Cáncer ←→ ☉ Sagitario</h3>
      <p class="text-silver-300 text-sm leading-relaxed max-w-lg mx-auto">
        Edward busca refugio, hogar y profundidad emocional. Martina necesita expansión, libertad y movimiento.
        La convivencia intensifica esta tensión porque el hogar es exactamente donde choca lo que cada uno necesita.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
      <!-- What unites -->
      <div>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-8 rounded-full bg-emerald-500/20 flex items-center justify-center border border-emerald-500/30">
            <span class="text-emerald-400 text-sm">✦</span>
          </div>
          <h3 class="font-serif text-2xl text-star-white">Lo que une</h3>
        </div>
        <div class="space-y-4">
          {synastryConnections.map((conn) => (
            <div class="card synastry-union border-emerald-900/40 hover:border-emerald-500/30 transition-all duration-300"
                 style="background: linear-gradient(135deg, rgba(16,185,129,0.04), rgba(13,13,43,0.8))">
              <div class="flex items-start gap-3">
                <span class="text-emerald-400 text-2xl mt-0.5">{conn.icon}</span>
                <div>
                  <h4 class="font-serif text-lg text-star-white mb-2">{conn.title}</h4>
                  <p class="text-silver-300 text-sm leading-relaxed">{conn.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- What tensions -->
      <div>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-8 rounded-full bg-red-500/20 flex items-center justify-center border border-red-500/30">
            <span class="text-red-400 text-sm">⊕</span>
          </div>
          <h3 class="font-serif text-2xl text-star-white">Lo que tensiona</h3>
        </div>
        <div class="space-y-4">
          {synastryTensions.map((tension) => (
            <div class="card synastry-discord border-red-900/30 hover:border-red-500/20 transition-all duration-300"
                 style="background: linear-gradient(135deg, rgba(239,68,68,0.04), rgba(13,13,43,0.8))">
              <div class="flex items-start gap-3">
                <span class="text-red-400 text-2xl mt-0.5 font-mono">{tension.icon}</span>
                <div>
                  <h4 class="font-serif text-lg text-star-white mb-2">{tension.title}</h4>
                  <p class="text-silver-300 text-sm leading-relaxed">{tension.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
